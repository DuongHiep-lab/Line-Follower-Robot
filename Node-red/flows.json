    {
        "id": "881cde11fd3df033",
        "type": "function",
        "z": "c199fe95d3dc847b",
        "name": "function 5",
        "func": "// 1. ĐỌC TRẠNG THÁI TỪ BỘ NHỚ (Ép kiểu Number để chống lỗi phím M)\nlet currentMode = Number(flow.get(\"robotMode\")) || 0;\nlet outData = {};\nlet displayStatus = \"\";\nlet buttonState = null;\nlet targetMode = currentMode;\nlet validCommand = false;\n\n// 2. PHÂN LOẠI TÍN HIỆU ĐẦU VÀO\n// --------------------------------------------------------\n// LUỒNG A: Tín hiệu từ CÔNG TẮC (Nhận diện qua topic \"mode\")\nif (msg.topic === \"mode\") {\n    // Chấp nhận cả định dạng số (1/0), boolean (true/false) hoặc chữ (\"1\"/\"0\")\n    targetMode = (msg.payload === true || msg.payload === 1 || msg.payload === \"1\") ? 1 : 0;\n    validCommand = true;\n}\n// --------------------------------------------------------\n// LUỒNG B: Tín hiệu từ DẢI NÚT BẤM (Nhận diện qua topic \"dir\")\nelse if (msg.topic === \"dir\") {\n    let val = String(msg.payload).toUpperCase();\n    if ([\"F\", \"B\", \"L\", \"R\", \"S\"].includes(val)) {\n        targetMode = 0; // Hễ bấm nút lái là ép xe về chế độ Manual\n        outData.dir = val;\n        buttonState = val; // Sáng nút tương ứng\n        validCommand = true;\n\n        if (val === \"F\") displayStatus = \"Tiến ⬆️\";\n        else if (val === \"B\") displayStatus = \"Lùi ⬇️\";\n        else if (val === \"L\") displayStatus = \"Trái ⬅️\";\n        else if (val === \"R\") displayStatus = \"Phải ➡️\";\n        else if (val === \"S\") displayStatus = \"DỪNG 🛑\";\n    }\n}\n// --------------------------------------------------------\n// LUỒNG C: Tín hiệu từ BÀN PHÍM WASD (Không có topic)\nelse {\n    let k = \"\";\n    // Bắt dính phím dù Node-RED gửi dưới dạng Object hay String\n    if (typeof msg.payload === \"object\" && msg.payload.key) {\n        k = String(msg.payload.key).toUpperCase();\n    } else if (typeof msg.payload === \"string\") {\n        k = msg.payload.toUpperCase();\n    }\n\n    if (k === 'M') {\n        targetMode = (currentMode === 0) ? 1 : 0; // Phím M: Đảo chế độ\n        validCommand = true;\n    }\n    else if ([\"W\", \"S\", \"A\", \"D\", \"X\"].includes(k)) {\n        targetMode = 0; // Hễ gõ phím lái là ép xe về chế độ Manual\n        validCommand = true;\n        if (k === 'W') { outData.dir = \"F\"; displayStatus = \"Tiến (Phím) ⬆️\"; buttonState = \"F\"; }\n        else if (k === 'S') { outData.dir = \"B\"; displayStatus = \"Lùi (Phím) ⬇️\"; buttonState = \"B\"; }\n        else if (k === 'A') { outData.dir = \"L\"; displayStatus = \"Trái (Phím) ⬅️\"; buttonState = \"L\"; }\n        else if (k === 'D') { outData.dir = \"R\"; displayStatus = \"Phải (Phím) ➡️\"; buttonState = \"R\"; }\n        else if (k === 'X') { outData.dir = \"S\"; displayStatus = \"DỪNG KHẨN CẤP 🛑\"; buttonState = \"S\"; } // Dùng phím X để phanh\n    }\n}\n\n// 3. LỌC NHIỄU\n// Nếu nhận được tín hiệu rác (ví dụ chuột lướt qua màn hình), hủy lệnh ngay lập tức\nif (!validCommand) return null;\n\n// 4. ĐÓNG GÓI VÀ LƯU TRỮ TRẠNG THÁI MỚI\ncurrentMode = targetMode;\nflow.set(\"robotMode\", currentMode);\noutData.mode = currentMode;\n\n// Xử lý hiển thị chữ trên màn hình khi ở trạng thái chờ\nif (currentMode === 1 && !outData.dir) {\n    displayStatus = \"Đang chạy AUTO 🤖\";\n    buttonState = \"\"; // Tắt highlight các nút di chuyển\n} else if (currentMode === 0 && !displayStatus) {\n    displayStatus = \"Đang chờ lệnh 🕹️\";\n}\n\n// 5. XUẤT RA 4 CỔNG KẾT NỐI\nreturn [\n    { topic: \"uet/robot/control\", payload: JSON.stringify(outData) }, // Cổng 1: Ra MQTT bắn xuống xe\n    { payload: displayStatus },                                       // Cổng 2: Ra màn hình Text\n    { payload: buttonState },                                         // Cổng 3: Dội ngược về Button Group để sáng nút\n    { payload: currentMode }                                          // Cổng 4: Dội ngược về Switch để gạt công tắc\n];",
        "outputs": 4,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 980,
        "y": 480,
        "wires": [
