    {
        "id": "0b970dbb6c5b7c38",
        "type": "function",
        "z": "c199fe95d3dc847b",
        "name": "function 2",
        "func": "// 1. Lưu giá trị của thanh trượt vừa kéo vào bộ nhớ flow\nflow.set(msg.topic, msg.payload);\n\n// 2. Lấy tất cả giá trị ra (nếu chưa có thì lấy mặc định)\nlet val_kp = flow.get(\"kp\") || 0;\nlet val_ki = flow.get(\"ki\") || 0;\nlet val_kd = flow.get(\"kd\") || 0;\nlet val_base = flow.get(\"base\") || 300; // Tốc độ mặc định là 300\n\n// 3. Đóng gói thành Object JSON bao gồm cả Base\nlet outData = {\n    \"Kp\": val_kp,\n    \"Ki\": val_ki,\n    \"Kd\": val_kd,\n    \"Base\": val_base\n};\n\n// 4. Gửi dữ liệu đi qua MQTT\nmsg.topic = \"uet/robot/control\";\nmsg.payload = JSON.stringify(outData);\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
