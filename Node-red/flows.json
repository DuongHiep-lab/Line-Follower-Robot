        "width": 0,
        "height": 0,
        "head": "",
        "format": "<template>\n    <span style=\"display:none\">Keyboard Listener</span>\n</template>\n\n<script>\nexport default {\n    mounted() {\n        // Bật camera giám sát bàn phím khi mở web\n        window.addEventListener('keydown', this.handleKeydown);\n    },\n    unmounted() {\n        // Tắt camera khi đóng web\n        window.removeEventListener('keydown', this.handleKeydown);\n    },\n    methods: {\n        handleKeydown(event) {\n            // Đóng gói phím vừa bấm và bắn thẳng về Node-RED\n            this.send({ payload: event.key }); \n        }\n    }\n}\n</script>",
